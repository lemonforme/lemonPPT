{
  "name": "@lemonppt/cli",
  "version": "0.1.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lemonppt": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "SKILL.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lemonforme/lemonPPT.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lemonforme/lemonPPT/issues"
  },
  "homepage": "https://github.com/lemonforme/lemonPPT#readme",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc && node scripts/copy-skill.mjs"
  },
  "dependencies": {
    "@lemonppt/agent-prompts": "workspace:*",
    "@lemonppt/core": "workspace:*",
    "@lemonppt/renderer": "workspace:*",
    "@lemonppt/themes": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
