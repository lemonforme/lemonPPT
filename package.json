{
  "name": "lemonppt",
  "version": "0.1.6",
  "private": true,
  "description": "Self-developed AI PPT generation agent. Independent from dashi-ppt-skill.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @lemonppt/server dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "render": "node scripts/render.mjs",
    "render:editor": "node scripts/render-editor.mjs",
    "export:pptx": "node scripts/export-pptx.mjs",
    "export:pdf": "node scripts/export-pdf.mjs",
    "generate:goal": "node scripts/generate-goal.mjs",
    "gallery": "node scripts/gallery.mjs",
    "publish:packages": "corepack pnpm -r publish"
  },
  "dependencies": {
    "@lemonppt/agent-prompts": "workspace:*",
    "@lemonppt/core": "workspace:*",
    "@lemonppt/renderer": "workspace:*"
  },
  "devDependencies": {
    "@lemonppt/templates": "workspace:*",
    "@types/supertest": "^7.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.2.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lemonforme/lemonPPT.git"
  },
  "bugs": {
    "url": "https://github.com/lemonforme/lemonPPT/issues"
  },
  "homepage": "https://github.com/lemonforme/lemonPPT#readme",
  "license": "AGPL-3.0"
}
